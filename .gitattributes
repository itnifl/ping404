# Auto-detect text files and normalize line endings
* text=auto

# Java files
*.java text eol=lf

# Gradle files
*.gradle text eol=lf
*.properties text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf

# Markdown
*.md text eol=lf

# JSON/YAML
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
